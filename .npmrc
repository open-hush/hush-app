# Expo / React Native + pnpm.
#
# Metro (the RN bundler) does not reliably resolve pnpm's default symlinked,
# strictly-isolated node_modules. `node-linker=hoisted` lays out a flat,
# npm/yarn-style node_modules so Metro and the native build tooling find every
# package where they expect it. This is the layout Expo documents for pnpm.
node-linker=hoisted

# Pin every dependency to an exact version (no ^ / ~ ranges). Org-wide rule.
#
# Exception: Expo SDK packages keep a `~` tilde range in package.json so that
# `expo install` / `expo-doctor` can align them to the versions the installed
# SDK expects on every SDK bump. This covers `expo`, `expo-*`, and the native
# libs Expo versions (react-native-screens, -reanimated, -gesture-handler,
# -safe-area-context, async-storage). `react`/`react-dom`/`react-native` stay
# exact, matching the official Expo template. Everything else stays exact.
# A `~` on a non-Expo dependency in a diff is still a bug.
save-exact=true
