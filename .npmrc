# Expo / React Native + pnpm.
#
# Metro (the RN bundler) does not reliably resolve pnpm's default symlinked,
# strictly-isolated node_modules. `node-linker=hoisted` lays out a flat,
# npm/yarn-style node_modules so Metro and the native build tooling find every
# package where they expect it. This is the layout Expo documents for pnpm.
node-linker=hoisted

# Pin every dependency to an exact version (no ^ / ~ ranges). Org-wide rule.
save-exact=true
